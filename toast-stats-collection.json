          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response has districts array', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.districts).to.be.an('array');",
              "    pm.expect(jsonData.districts.length).to.be.greaterThan(0);",
              "});"
            ],
            "type": "text/javascript"
          }
