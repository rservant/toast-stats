# Production Environment Configuration for Club Health Classification System

# Server Configuration
PORT=5001
NODE_ENV=production

# Toastmasters Dashboard URL
TOASTMASTERS_DASHBOARD_URL=https://dashboards.toastmasters.org

# Use real data in production
USE_MOCK_DATA=false

# JWT Configuration (CHANGE THESE IN PRODUCTION)
JWT_SECRET=your-production-secret-key-minimum-32-characters-long
JWT_EXPIRES_IN=24h

# Cache Configuration
CACHE_DIR=/app/cache
CACHE_TTL=1800
CACHE_MAX_SIZE=1000

# Club Health Cache Configuration
CLUB_HEALTH_CACHE_TTL=1800
CLUB_HEALTH_HISTORY_CACHE_TTL=3600
DISTRICT_SUMMARY_CACHE_TTL=1200

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000
RATE_LIMIT_CLUB_HEALTH_MAX=100
RATE_LIMIT_BATCH_MAX=10
RATE_LIMIT_HISTORY_MAX=50
RATE_LIMIT_SUMMARY_MAX=20

# CORS Configuration
CORS_ORIGIN=https://yourdomain.com
CORS_CREDENTIALS=true

# Database Configuration (if using database)
# DATABASE_URL=postgresql://username:password@localhost:5432/toastmasters_db
# DATABASE_POOL_MIN=2
# DATABASE_POOL_MAX=10

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE=/app/logs/application.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5

# Security Configuration
HELMET_ENABLED=true
TRUST_PROXY=true
SESSION_SECRET=your-session-secret-change-in-production

# Performance Configuration
COMPRESSION_ENABLED=true
COMPRESSION_LEVEL=6
COMPRESSION_THRESHOLD=1024

# Health Check Configuration
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PATH=/health
HEALTH_CHECK_TIMEOUT=5000

# Monitoring Configuration
METRICS_ENABLED=true
METRICS_PATH=/metrics
PROMETHEUS_ENABLED=false

# Club Health Specific Configuration
CLUB_HEALTH_RULE_VERSION=1.0.0
CLUB_HEALTH_BATCH_SIZE_LIMIT=100
CLUB_HEALTH_PROCESSING_TIMEOUT=30000
CLUB_HEALTH_RETRY_ATTEMPTS=3
CLUB_HEALTH_RETRY_DELAY=1000

# Data Integration Configuration
INTEGRATION_TIMEOUT=10000
INTEGRATION_RETRY_ATTEMPTS=3
INTEGRATION_BATCH_SIZE=50

# Alert Configuration
ALERT_ENABLED=true
ALERT_WEBHOOK_URL=https://your-webhook-url.com/alerts
ALERT_THRESHOLD_ERROR_RATE=0.05
ALERT_THRESHOLD_RESPONSE_TIME=5000

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=your-backup-bucket

# Feature Flags
FEATURE_REAL_TIME_UPDATES=false
FEATURE_ADVANCED_ANALYTICS=true
FEATURE_EXPORT_FUNCTIONALITY=true
FEATURE_AUDIT_LOGGING=true