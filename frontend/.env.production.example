# Production Environment Configuration for Club Health Dashboard

# API Configuration
VITE_API_BASE_URL=https://api.yourdomain.com/api

# Environment
VITE_ENV=production

# Application Configuration
VITE_APP_NAME=Club Health Dashboard
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Toastmasters Club Health Classification System

# Feature Flags
VITE_FEATURE_REAL_TIME_UPDATES=false
VITE_FEATURE_ADVANCED_ANALYTICS=true
VITE_FEATURE_EXPORT_FUNCTIONALITY=true
VITE_FEATURE_DEBUG_MODE=false

# Analytics Configuration
VITE_ANALYTICS_ENABLED=true
VITE_ANALYTICS_ID=your-analytics-id

# Error Tracking
VITE_ERROR_TRACKING_ENABLED=true
VITE_ERROR_TRACKING_DSN=your-error-tracking-dsn

# Performance Monitoring
VITE_PERFORMANCE_MONITORING=true
VITE_PERFORMANCE_SAMPLE_RATE=0.1

# Cache Configuration
VITE_CACHE_VERSION=1.0.0
VITE_CACHE_ENABLED=true

# Security Configuration
VITE_CSP_ENABLED=true
VITE_HTTPS_ONLY=true

# Branding Configuration
VITE_BRAND_PRIMARY_COLOR=#004165
VITE_BRAND_SECONDARY_COLOR=#772432
VITE_BRAND_ACCENT_COLOR=#F2DF74

# Contact Information
VITE_SUPPORT_EMAIL=support@yourdomain.com
VITE_SUPPORT_PHONE=+1-555-0123
VITE_DOCUMENTATION_URL=https://docs.yourdomain.com

# Legal Information
VITE_PRIVACY_POLICY_URL=https://yourdomain.com/privacy
VITE_TERMS_OF_SERVICE_URL=https://yourdomain.com/terms