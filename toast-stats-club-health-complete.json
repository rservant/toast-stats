  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": ["{{base_url}}"],
          "path": ["health"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response has status ok', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.status).to.eql('ok');",
              "});",
              "",
              "pm.test('Club health service is available', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.services.clubHealth.status).to.eql('ok');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Club Health - Single Classification (Valid)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"club_name\": \"Test Club\",\n  \"current_members\": 25,\n  \"member_growth_since_july\": 5,\n  \"current_month\": \"October\",\n  \"dcp_goals_achieved_ytd\": 3,\n  \"csp_submitted\": true,\n  \"officer_list_submitted\": true,\n  \"officers_trained\": true,\n  \"previous_month_members\": 23,\n  \"previous_month_dcp_goals_achieved_ytd\": 2,\n  \"previous_month_health_status\": \"Vulnerable\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/club-health/classify",
          "host": ["{{base_url}}"],
          "path": ["api", "club-health", "classify"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response has success true', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.success).to.be.true;",
              "});",
              "",
              "pm.test('Response has classification data', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.data).to.be.an('object');",
              "    pm.expect(jsonData.data.club_name).to.eql('Test Club');",
              "    pm.expect(jsonData.data.health_status).to.be.a('string');",
              "    pm.expect(jsonData.data.trajectory).to.be.a('string');",
              "    pm.expect(jsonData.data.composite_key).to.be.a('string');",
              "    pm.expect(jsonData.data.composite_label).to.be.a('string');",
              "});",
              "",
              "pm.test('Response has metadata', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.metadata).to.be.an('object');",
              "    pm.expect(jsonData.metadata.timestamp).to.be.a('string');",
              "    pm.expect(jsonData.metadata.api_processing_time_ms).to.be.a('number');",
              "});",
              "",
              "pm.test('Classification result is valid', function () {",
              "    const jsonData = pm.response.json();",
              "    const validHealthStatuses = ['Thriving', 'Vulnerable', 'Intervention Required'];",
              "    const validTrajectories = ['Improving', 'Stable', 'Declining', 'Recovering'];",
              "    ",
              "    pm.expect(validHealthStatuses).to.include(jsonData.data.health_status);",
              "    pm.expect(validTrajectories).to.include(jsonData.data.trajectory);",
              "    pm.expect(jsonData.data.reasons).to.be.an('array');",
              "    pm.expect(jsonData.data.trajectory_reasons).to.be.an('array');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Club Health - Batch Classification (Valid)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "[\n  {\n    \"club_name\": \"Batch Club 1\",\n    \"current_members\": 15,\n    \"member_growth_since_july\": 2,\n    \"current_month\": \"October\",\n    \"dcp_goals_achieved_ytd\": 2,\n    \"csp_submitted\": false,\n    \"officer_list_submitted\": true,\n    \"officers_trained\": false,\n    \"previous_month_members\": 13,\n    \"previous_month_dcp_goals_achieved_ytd\": 1,\n    \"previous_month_health_status\": \"Vulnerable\"\n  },\n  {\n    \"club_name\": \"Batch Club 2\",\n    \"current_members\": 30,\n    \"member_growth_since_july\": 8,\n    \"current_month\": \"October\",\n    \"dcp_goals_achieved_ytd\": 5,\n    \"csp_submitted\": true,\n    \"officer_list_submitted\": true,\n    \"officers_trained\": true,\n    \"previous_month_members\": 28,\n    \"previous_month_dcp_goals_achieved_ytd\": 4,\n    \"previous_month_health_status\": \"Thriving\"\n  }\n]"
        },
        "url": {
          "raw": "{{base_url}}/api/club-health/batch",
          "host": ["{{base_url}}"],
          "path": ["api", "club-health", "batch"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response has success true', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.success).to.be.true;",
              "});",
              "",
              "pm.test('Response has batch results', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.data).to.be.an('array');",
              "    pm.expect(jsonData.data).to.have.lengthOf(2);",
              "});",
              "",
              "pm.test('Batch metadata is correct', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.metadata.total_clubs).to.eql(2);",
              "    pm.expect(jsonData.metadata.successful_classifications).to.eql(2);",
              "    pm.expect(jsonData.metadata.api_processing_time_ms).to.be.a('number');",
              "});",
              "",
              "pm.test('Each result has required fields', function () {",
              "    const jsonData = pm.response.json();",
              "    jsonData.data.forEach((result, index) => {",
              "        pm.expect(result.club_name).to.include('Batch Club');",
              "        pm.expect(result.health_status).to.be.a('string');",
              "        pm.expect(result.trajectory).to.be.a('string');",
              "        pm.expect(result.composite_key).to.be.a('string');",
              "        pm.expect(result.reasons).to.be.an('array');",
              "    });",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
