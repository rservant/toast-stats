    {
      "name": "Club Health - Validation Error (Missing Fields)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"club_name\": \"Incomplete Club\",\n  \"current_members\": 25\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/club-health/classify",
          "host": ["{{base_url}}"],
          "path": ["api", "club-health", "classify"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 400', function () {",
              "    pm.response.to.have.status(400);",
              "});",
              "",
              "pm.test('Response has success false', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.success).to.be.false;",
              "});",
              "",
              "pm.test('Response has validation error', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.error).to.be.an('object');",
              "    pm.expect(jsonData.error.code).to.eql('VALIDATION_ERROR');",
              "    pm.expect(jsonData.error.message).to.be.a('string');",
              "    pm.expect(jsonData.error.details).to.be.an('array');",
              "});",
              "",
              "pm.test('Error details include missing fields', function () {",
              "    const jsonData = pm.response.json();",
              "    const details = jsonData.error.details;",
              "    const missingFields = details.filter(d => d.code === 'MISSING_REQUIRED_FIELD');",
              "    pm.expect(missingFields.length).to.be.greaterThan(0);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Club Health - Validation Error (Invalid Types)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"club_name\": \"Invalid Club\",\n  \"current_members\": \"not_a_number\",\n  \"member_growth_since_july\": 5,\n  \"current_month\": \"InvalidMonth\",\n  \"dcp_goals_achieved_ytd\": -1,\n  \"csp_submitted\": \"yes\",\n  \"officer_list_submitted\": true,\n  \"officers_trained\": true,\n  \"previous_month_members\": 23,\n  \"previous_month_dcp_goals_achieved_ytd\": 2,\n  \"previous_month_health_status\": \"InvalidStatus\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/club-health/classify",
          "host": ["{{base_url}}"],
          "path": ["api", "club-health", "classify"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 400', function () {",
              "    pm.response.to.have.status(400);",
              "});",
              "",
              "pm.test('Response has validation errors for invalid types', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.success).to.be.false;",
              "    pm.expect(jsonData.error.code).to.eql('VALIDATION_ERROR');",
              "    pm.expect(jsonData.error.details).to.be.an('array');",
              "});",
              "",
              "pm.test('Error details include type and value errors', function () {",
              "    const jsonData = pm.response.json();",
              "    const details = jsonData.error.details;",
              "    const typeErrors = details.filter(d => d.code === 'INVALID_FIELD_TYPE');",
              "    const valueErrors = details.filter(d => d.code === 'INVALID_FIELD_VALUE');",
              "    const monthErrors = details.filter(d => d.code === 'INVALID_MONTH');",
              "    const statusErrors = details.filter(d => d.code === 'INVALID_HEALTH_STATUS');",
              "    ",
              "    pm.expect(typeErrors.length).to.be.greaterThan(0);",
              "    pm.expect(valueErrors.length).to.be.greaterThan(0);",
              "    pm.expect(monthErrors.length).to.be.greaterThan(0);",
              "    pm.expect(statusErrors.length).to.be.greaterThan(0);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
