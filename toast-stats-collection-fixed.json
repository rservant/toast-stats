              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Get Districts",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/districts",
          "host": ["{{base_url}}"],
          "path": ["api", "districts"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response has districts array', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.districts).to.be.an('array');",
              "    pm.expect(jsonData.districts.length).to.be.greaterThan(0);",
              "});",
              "",
              "pm.test('Districts have id and name', function () {",
              "    const jsonData = pm.response.json();",
              "    const firstDistrict = jsonData.districts[0];",
              "    pm.expect(firstDistrict).to.have.property('id');",
              "    pm.expect(firstDistrict).to.have.property('name');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
